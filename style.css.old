/* ================= BASE ================= */
body {
  margin: 0;
  font-family: "Lato", sans-serif;
  background: #000;
  color: #fff;
}

/* ================= IMAGENS RESPONSIVAS ================= */
img {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 0 auto;
}

/* ================= HEADER ================= */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  background: #000;
  border-bottom: 1px solid #222;
  z-index: 1000;
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
}

.logo {
  font-weight: bold;
}

/* ================= HAMBURGER ================= */
.hamburger {
  font-size: 22px;
  cursor: pointer;
  background: none;
  border: none;
  color: #fff;
}

/* ================= MENU ================= */
.menu {
  display: none;
  flex-direction: column;
  background: #000;
  border-top: 1px solid #222;
}

.menu a {
  padding: 12px 16px;
  text-decoration: none;
  color: #fff;
  border-bottom: 1px solid #111;
  transition: background 0.2s ease;
}

.menu a:hover {
  background: #111;
}

.menu.active {
  display: flex;
}

/* ================= DESKTOP ================= */
@media (min-width: 768px) {

  .hamburger {
    display: none;
  }

  .menu {
    display: flex !important;
    flex-direction: row;
    border: none;
  }

  .menu a {
    border: none;
  }
}

/* ================= MAIN ================= */
main {
  margin-top: 70px;
  padding: 20px;
  text-align: center;
}

/* ================= HERO ================= */
.hero {
  padding: 40px 20px;
}

.hero img {
  max-width: 100%;
  width: auto;
}

.hero-text {
  font-size: 1.1rem;
  color: #ccc;
  margin: 20px 0 30px;
  line-height: 1.6;
}

/* ================= BOTÃO CTA ================= */
.cta-btn {
  display: inline-block;

  padding: 18px 36px;

  background: linear-gradient(135deg, #ff7a18, #ff3d00);

  color: #ffffff;

  font-size: 1.2rem;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-decoration: none;

  border-radius: 14px;

  box-shadow:
    0 6px 18px rgba(255, 61, 0, 0.35),
    0 0 12px rgba(255, 122, 24, 0.25);

  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease,
    filter 0.2s ease;

  margin-top: 20px;
}

/* Hover desktop */
.cta-btn:hover {
  transform: translateY(-3px) scale(1.02);

  box-shadow:
    0 10px 24px rgba(255, 61, 0, 0.45),
    0 0 18px rgba(255, 122, 24, 0.35);

  filter: brightness(1.05);
}

/* Clique */
.cta-btn:active {
  transform: scale(0.98);
}

/* Acessibilidade teclado */
.cta-btn:focus {
  outline: 3px solid #ffffff;
  outline-offset: 4px;
}

/* ================= ACESSIBILIDADE ================= */
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* ================= SLIDESHOW ================= */
.slideshow {
  position: relative;
  max-width: 100%;
  overflow: hidden;
}

/* Cada slide ocupa o mesmo espaço */
.mySlides {
  display: none;
  width: 100%;
}

/* Imagem responsiva */
.mySlides img {
  width: 100%;
  height: auto;
}

/* Slide ativo */
.mySlides.active {
  display: block;
}

/* ================= RESPONSIVO ================= */
@media (max-width: 768px) {

  .cta-btn {
    width: 100%;
    max-width: 320px;

    text-align: center;

    font-size: 1.1rem;

    padding: 16px 24px;
  }

}
